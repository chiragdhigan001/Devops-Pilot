# DevOpsPilot AI - Environment Variables
# Copy this file to apps/backend/.env and fill in the values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/devopspilot

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_random_secret_key
JWT_REFRESH_SECRET=change_this_to_another_random_secret_key
JWT_EXPIRES_IN=7d

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth - GitHub
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Deployment runner
DEPLOYMENTS_ROOT=./tmp/deployments
DEPLOY_BASE_PORT=4000
DEPLOY_URL_HOST=127.0.0.1
DEPLOY_ROUTER_TARGET_HOST=127.0.0.1

# Public routing
PLATFORM_BASE_DOMAIN=lvh.me
PLATFORM_PUBLIC_PROTOCOL=http
PLATFORM_PUBLIC_PORT=5000
